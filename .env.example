# ==============================================================================
# AI-Powered Content Assistant - Environment Variables
#
# Instructions:
# 1. Copy this file to a new file named .env in the root directory.
# 2. Fill in the values for your local development environment.
# 3. The .env file is ignored by Git (see .gitignore) and should NOT be
#    committed to the repository.
# ==============================================================================


# ------------------------------------------------------------------------------
# Global / Docker Compose Configuration
# ------------------------------------------------------------------------------
# These variables are primarily used by docker-compose.yml to configure the
# services and their port mappings for local development.

# The host port to map to the React frontend container.
FRONTEND_PORT=3000

# The host port to map to the Node.js API Gateway container.
API_GATEWAY_PORT=5000

# The host port to map to the Python AI Service container.
AI_SERVICE_PORT=8000


# ------------------------------------------------------------------------------
# React Frontend (frontend)
# ------------------------------------------------------------------------------
# The URL of the API Gateway that the frontend will communicate with.
# This must be prefixed with REACT_APP_ for Create React App to expose it to the browser.
# This should point to the API Gateway's host port.
REACT_APP_API_GATEWAY_URL=http://localhost:5000/api


# ------------------------------------------------------------------------------
# Node.js API Gateway (api-gateway)
# ------------------------------------------------------------------------------
# The internal port the API Gateway server will listen on inside its container.
# This should match the container-side port defined in docker-compose.yml.
PORT=5000

# The URL of the downstream AI service.
# 'ai-service' is the service name defined in docker-compose.yml, which Docker
# resolves to the correct container IP address.
AI_SERVICE_URL=http://ai-service:8000

# Allowed origins for Cross-Origin Resource Sharing (CORS).
# For local development, this is the frontend's URL.
# For production, set this to your frontend's domain.
# Use '*' for a permissive setting (not recommended for production).
CORS_ORIGIN=http://localhost:3000

# Logging level for the application (e.g., 'info', 'debug', 'warn', 'error').
LOG_LEVEL=info

# Optional: Rate limiting configuration
# RATE_LIMIT_WINDOW_MS=60000 # 1 minute in milliseconds
# RATE_LIMIT_MAX_REQUESTS=100 # Max requests per window per IP


# ------------------------------------------------------------------------------
# Python AI Service (ai-service)
# ------------------------------------------------------------------------------
# The internal port the Python Flask/FastAPI server will listen on.
# This should match the container-side port defined in docker-compose.yml.
PORT=8000

# Logging level for the Python service (e.g., 'INFO', 'DEBUG', 'WARNING', 'ERROR').
LOG_LEVEL=INFO

# Configuration for the AI models.
# This could be a local model name from a library like Hugging Face Transformers
# or an identifier for a cloud-based service.
SUMMARIZATION_MODEL_NAME=sshleifer/distilbart-cnn-12-6

# Optional: API Key for a third-party AI provider (e.g., OpenAI, Cohere, Anthropic).
# Leave blank if using a local, self-hosted model.
# OPENAI_API_KEY=your_openai_api_key_here
# COHERE_API_KEY=your_cohere_api_key_here